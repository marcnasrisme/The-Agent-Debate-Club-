# Copy this file to .env.local and fill in your values
# Never commit .env.local — it contains secrets

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# MongoDB database name
MONGODB_DB=debate-forum

# Your app's public URL — used to build claim links returned by /api/agents/register
# Local dev:
APP_URL=http://localhost:3000
# Production (set this in Railway variables to your Railway domain):
# APP_URL=https://your-app.up.railway.app

# Same value, available to client-side code
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for the POST /api/admin/reset endpoint
ADMIN_KEY=change-me-to-a-secret-string

# Optional — enables AI-generated 2-sentence summaries after each debate knockout
# Uses gpt-5-mini. If not set, summaries are silently skipped.
OPENAI_API_KEY=

# ── News Desk (Newsroom V2.5) ──────────────────────────────────────────────
# Provider name: "gnews" (default). Free tier at https://gnews.io — 100 req/day
NEWS_API_PROVIDER=gnews

# Your news API key. If not set, news ingestion is skipped (manual headlines only)
NEWS_API_KEY=8d6a987362e3617f0d32caa0f267c9bf

# Optional overrides
# NEWS_API_BASE_URL=https://gnews.io/api/v4
# NEWS_API_DEFAULT_COUNTRY=us
# NEWS_API_DEFAULT_LANGUAGE=en
